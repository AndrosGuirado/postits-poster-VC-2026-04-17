:root
	// Colors — brand
	--yellow #F2F745
	--white  #f5f5f0

	// Colors — UI
	--bg          #2b2b2b
	--bg-elevated #363636
	--border      rgba(255, 255, 255, 0.08)

	// Colors — text
	--text-primary   #f5f5f0
	--text-secondary rgba(245, 245, 240, 0.55)
	--text-disabled  rgba(245, 245, 240, 0.25)

	// Typography — families
	--font-sans  'Inter', system-ui, sans-serif
	--font-mono  'JetBrains Mono', 'Fira Code', monospace

	// Typography — sizes
	--text-xs   12px
	--text-sm   14px
	--text-base 16px
	--text-lg   20px
	--text-xl   24px
	--text-2xl  32px
	--text-3xl  48px

	// Typography — weights
	--weight-regular 400
	--weight-medium  500
	--weight-bold    700

	// Spacing
	--space-1  4px
	--space-2  8px
	--space-3  12px
	--space-4  16px
	--space-5  24px
	--space-6  32px
	--space-8  48px
	--space-10 64px

	// Layout
	--page-max-width 794px
	--page-padding   40px

	// Radius
	--radius-sm 4px
	--radius-md 8px
	--radius-lg 16px

	// Shadows
	--shadow-paper 0 4px 32px rgba(0, 0, 0, 0.5)
	--shadow-sm    0 1px 4px rgba(0, 0, 0, 0.3)

	// Transitions
	--duration-fast   120ms
	--duration-normal 220ms
	--ease            cubic-bezier(1, 0.06, 0, 1.04)


svg
	width 100%
	height 100%